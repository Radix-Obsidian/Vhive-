# Vhive - API Keys Only (No LLM keys needed - local Ollama only)
# Copy this file to .env and fill in your values

# Shopify Admin API
# Get from: store.myshopify.com/admin → Settings → Apps → Develop apps → Create app → Install
SHOPIFY_SHOP_DOMAIN=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
SHOPIFY_API_VERSION=2026-01

# Twitter API v2
# Get from: developer.twitter.com/en/portal/dashboard
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# Telegram Bot API
# Create bot: t.me/BotFather → /newbot
# Get chat ID: message bot, then call https://api.telegram.org/bot{TOKEN}/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=

# iMessage — no keys needed. Sign into Messages.app with Apple ID on this Mac.

# OpenHands (optional - if using remote agent server instead of local Docker)
OPENHANDS_API_URL=
OPENHANDS_API_KEY=

# ── Vhive Server Security ────────────────────────────────
# API key (auto-generated at ~/.vhive/api_key if not set here)
VHIVE_API_KEY=

# CORS allowed origins (comma-separated, defaults to localhost:5174)
VHIVE_CORS_ORIGINS=http://localhost:5174,http://127.0.0.1:5174
