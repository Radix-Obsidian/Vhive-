# Vhive - API Keys Only (No LLM keys needed - local Ollama only)
# Copy this file to .env and fill in your values

# ── GitHub (required for product deploy) ─────────────────────────
# Create at: github.com/settings/tokens → Fine-grained → repo write + metadata read
GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxx
# Optional: deploy to an org instead of your personal account
GITHUB_ORG=

# ── Vercel (required for product deploy) ─────────────────────────
# Create at: vercel.com/account/tokens
# Prerequisite: install the Vercel GitHub App on your account/org
VERCEL_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: team slug if using a Vercel team
VERCEL_TEAM_ID=

# ── Stripe (optional — enables revenue tracking) ─────────────────
# Get from: dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=your_stripe_secret_key_here
# Webhook secret for /api/webhooks/stripe endpoint
# Get from: dashboard.stripe.com/webhooks after adding the endpoint
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# Twitter API v2
# Get from: developer.twitter.com/en/portal/dashboard
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# Telegram Bot API
# Create bot: t.me/BotFather → /newbot
# Get chat ID: message bot, then call https://api.telegram.org/bot{TOKEN}/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=

# iMessage — no keys needed. Sign into Messages.app with Apple ID on this Mac.

# OpenHands (optional - if using remote agent server instead of local Docker)
OPENHANDS_API_URL=
OPENHANDS_API_KEY=

# ── Vhive Server Security ────────────────────────────────
# API key (auto-generated at ~/.vhive/api_key if not set here)
VHIVE_API_KEY=

# CORS allowed origins (comma-separated, defaults to localhost:5174)
VHIVE_CORS_ORIGINS=http://localhost:5174,http://127.0.0.1:5174
